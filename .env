# If you can't bind port 53 to 0.0.0.0, then check if systemd-resolved is running. You either set HOST_IP to another ip, or disable systemd-resolved.
# see /etc/systemd/resolved.conf.d/noresolved.conf and add DNSStubListener=no. Then run sudo systemctl restart systemd-resolved
HOST_IP=172.16.0.90

DNSCRYPT_VER=2.1.16
DNSCRYPT_UI_PORT=81

PI_HOLE_VERSION=2026.05.0
PI_HOLE_WEB_ADMIN_PORT=5080
